# ─── 服务器 ─────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=9800

# ─── 安全（务必修改！）────────────────────────────────────────────
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── 管理员账号 ──────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-in-production

# ─── AI 模型配置 ─────────────────────────────────────────────────
POLISH_MODEL=gpt-4o
POLISH_API_KEY=sk-xxxx
POLISH_BASE_URL=https://api.openai.com/v1

ENHANCE_MODEL=gpt-4o
ENHANCE_API_KEY=sk-xxxx
ENHANCE_BASE_URL=https://api.openai.com/v1

EMOTION_MODEL=
EMOTION_API_KEY=
EMOTION_BASE_URL=

COMPRESSION_MODEL=gpt-4o-mini
COMPRESSION_API_KEY=sk-xxxx
COMPRESSION_BASE_URL=https://api.openai.com/v1

# ─── 系统参数 ────────────────────────────────────────────────────
MAX_CONCURRENT_USERS=5
DEFAULT_USAGE_LIMIT=0
SEGMENT_SKIP_THRESHOLD=15
API_REQUEST_INTERVAL=6
USE_STREAMING=False
HISTORY_COMPRESSION_THRESHOLD=5000
THINKING_MODE_ENABLED=True
THINKING_MODE_EFFORT=high
MAX_UPLOAD_FILE_SIZE_MB=0
